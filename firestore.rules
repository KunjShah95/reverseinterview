rules_version = '2';

// Firestore security rules for OfferGuard AI.
//
// Deploy with: firebase deploy --only firestore:rules
// (requires firebase.json pointing "firestore.rules" at this file).

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user saved reports. Only the signed-in owner can read or write their
    // own reports subcollection. The client Firebase SDK (src/lib/firestore.ts)
    // writes here as the authenticated user.
    match /users/{uid}/reports/{reportId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // In-flight analysis job state. Written exclusively by the server via the
    // Firebase Admin SDK (src/lib/job-store.server.ts), which bypasses these
    // rules. No client ever touches this collection directly, so deny all
    // client access.
    match /analysisJobs/{jobId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
