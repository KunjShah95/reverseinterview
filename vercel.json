{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "routes": [
    {
      "src": "^/(?!.*\\.).*",
      "methods": ["GET"],
      "has": [
        { "type": "cookie", "key": "__session", "missing": true },
        { "type": "header", "key": "accept", "value": "text/html" }
      ],
      "status": 302,
      "destination": "/"
    },
    {
      "src": "(/.*)",
      "dest": "/api/index.js"
    }
  ]
}
